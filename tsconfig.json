{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": [
      "ES2020"
    ],
    "types": [
      "google-apps-script",
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.gs",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}